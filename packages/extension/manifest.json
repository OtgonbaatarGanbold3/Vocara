{
  "manifest_version": 3,
  "name": "Vocara",
  "version": "1.0.0",
  "description": "Learn languages while watching movies — dual subtitles, instant translations, shadowing, dictation, and AI-powered learning",
  "permissions": [
    "storage",
    "activeTab",
    "sidePanel",
    "scripting"
  ],
  "host_permissions": [
    "https://www.netflix.com/*",
    "https://www.youtube.com/*",
    "https://www.disneyplus.com/*",
    "https://www.primevideo.com/*",
    "https://www.amazon.com/gp/video/*"
  ],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.netflix.com/*",
        "https://www.youtube.com/*",
        "https://www.disneyplus.com/*",
        "https://www.primevideo.com/*",
        "https://www.amazon.com/gp/video/*"
      ],
      "js": ["src/content/index.ts"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "options_ui": {
    "page": "src/options/index.html",
    "open_in_tab": true
  },
  "web_accessible_resources": [
    {
      "resources": ["src/content/styles.css", "icons/*"],
      "matches": [
        "https://www.netflix.com/*",
        "https://www.youtube.com/*",
        "https://www.disneyplus.com/*",
        "https://www.primevideo.com/*",
        "https://www.amazon.com/*"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
